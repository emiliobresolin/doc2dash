# Reference environment file for the first hosted MVP path.
# This file is documentation only. The app reads real environment variables at runtime.
# The recommended Render Docker deployment already sets these values in the image.
# Use this file only if you want to override those defaults.

# Optional override for hosted same-origin mode.
DOC2DASH_FRONTEND_DIST_ROOT=/app/frontend-dist

# Optional override for hosted persistence. This path must be backed by a persistent disk.
DOC2DASH_UPLOADS_ROOT=/var/data/doc2dash-uploads

# Optional. Default is 30 MB.
DOC2DASH_MAX_UPLOAD_SIZE_BYTES=31457280
